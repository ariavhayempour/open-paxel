# Copy to .env and fill in your key ( .env is gitignored )
OPENAI_API_KEY=sk-your-key-here

# LLM provider: openai (default), openrouter, or ollama
# OPEN_PAXEL_LLM_PROVIDER=openai
# OPEN_PAXEL_MODEL=gpt-4.1-mini

# OpenRouter (https://openrouter.ai/)
# OPEN_PAXEL_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPEN_PAXEL_MODEL=openai/gpt-4o-mini
# OPEN_PAXEL_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local, no API key required)
# OPEN_PAXEL_LLM_PROVIDER=ollama
# OPEN_PAXEL_MODEL=llama3.2
# OPEN_PAXEL_OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional Open-Paxel settings
# OPEN_PAXEL_HOME=
# OPEN_PAXEL_CONCURRENCY=3

# Legacy env names (still supported):
# BRAIN_DUMP_MODEL=gpt-4.1-mini
# BRAIN_DUMP_HOME=

# ─────────────────────────────────────────────────────────────────────────
# Docker (docker compose up)
# ─────────────────────────────────────────────────────────────────────────
# Switching provider (OpenAI <-> OpenRouter <-> Ollama) only needs an edit
# here — no image rebuild. Keep every line strict KEY=VALUE or a # comment;
# docker compose rejects bare/parenthesized lines in an env file.
#
# Ollama base URL inside Docker. The OPEN_PAXEL_OLLAMA_BASE_URL above is for
# non-Docker dev (localhost); docker-compose.yml ignores it for the container and
# uses OPEN_PAXEL_DOCKER_OLLAMA_BASE_URL instead, so the two never collide:
#   - bundled service (docker compose --profile ollama up):
#       leave OPEN_PAXEL_DOCKER_OLLAMA_BASE_URL unset → defaults to http://ollama:11434/v1
#   - Ollama installed on the host machine instead:
#       OPEN_PAXEL_DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
#
# With the bundled profile, OPEN_PAXEL_MODEL selects BOTH the model the app
# requests and the model pulled into the ollama volume on first run.
# OPEN_PAXEL_HOME / OPEN_PAXEL_HOST are set by docker-compose.yml — leave them unset here.
