# Copy to .env and fill in your key ( .env is gitignored )
OPENAI_API_KEY=sk-your-key-here

# LLM provider: openai (default), openrouter, or ollama
# OPEN_PAXEL_LLM_PROVIDER=openai
# OPEN_PAXEL_MODEL=gpt-4.1-mini

# OpenRouter (https://openrouter.ai/)
# OPEN_PAXEL_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPEN_PAXEL_MODEL=openai/gpt-4o-mini
# OPEN_PAXEL_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local, no API key required)
# OPEN_PAXEL_LLM_PROVIDER=ollama
# OPEN_PAXEL_MODEL=llama3.2
# OPEN_PAXEL_OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional Open-Paxel settings
# OPEN_PAXEL_HOME=
# OPEN_PAXEL_CONCURRENCY=3

# Legacy env names (still supported):
# BRAIN_DUMP_MODEL=gpt-4.1-mini
# BRAIN_DUMP_HOME=
